{
  "name": "webmovies/app",
  "description": "Estrutura base do projeto WebMovies com rotas e namespaces",
  "type": "project",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "files": [
      "source/support/config.php",
       "source/support/helpers.php"
    ],
    "psr-4": {
      "WebMovies\\Controllers\\": "source/Controllers/",
      "WebMovies\\Controllers\\Web\\": "source/Controllers/Web/",
      "WebMovies\\Controllers\\Admin\\": "source/Controllers/Admin/",
      "WebMovies\\Models\\": "source/models/",
      "WebMovies\\Support\\": "source/support/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
